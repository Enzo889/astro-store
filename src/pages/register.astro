---
import AuthLayout from "@/layouts/AuthLayout.astro";

const email = Astro.cookies.get("email")?.value ?? "";
const rememberMe = !!email;
---

<AuthLayout>
  <div class="bg-white py-8 px-4 shadow-sm border border-gray-100 sm:rounded-xl sm:px-10">
    <div class="mb-6 text-center">
      <h3 class="font-semibold text-2xl text-gray-900 tracking-tight">Create an account</h3>
      <p class="text-sm text-gray-500 mt-1">Join us today</p>
    </div>
    <form class="space-y-5">
      <div class="space-y-1.5">
        <label class="block text-sm font-medium text-gray-700">Full name</label>
        <input
          class="block w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg appearance-none focus:outline-none focus:ring-2 focus:ring-gray-900/20 focus:border-gray-900 transition-all text-gray-800 sm:text-sm"
          type="text"
          name="name"
          placeholder="Jane Doe"
          required
        />
      </div>
      <div class="space-y-1.5">
        <label class="block text-sm font-medium text-gray-700">Email address</label>
        <input
          class="block w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg appearance-none focus:outline-none focus:ring-2 focus:ring-gray-900/20 focus:border-gray-900 transition-all text-gray-800 sm:text-sm"
          type="email"
          name="email"
          value={email}
          placeholder="Enter your email"
          required
        />
      </div>
      <div class="space-y-1.5">
        <label class="block text-sm font-medium text-gray-700">Password</label>
        <input
          class="block w-full px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg appearance-none focus:outline-none focus:ring-2 focus:ring-gray-900/20 focus:border-gray-900 transition-all text-gray-800 sm:text-sm"
          type="password"
          name="password"
          placeholder="Create a password"
          required
        />
      </div>
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <input
            id="remember_me"
            name="remember_me"
            checked={rememberMe}
            type="checkbox"
            class="h-4 w-4 text-gray-900 focus:ring-gray-900 border-gray-300 rounded cursor-pointer transition-colors"
          />
          <label for="remember_me" class="ml-2 block text-sm text-gray-600 cursor-pointer">
            Remember me
          </label>
        </div>
        <div class="text-sm">
          <a href="/login" class="font-medium text-gray-900 hover:text-gray-700 transition-colors">
            Already have an account?
          </a>
        </div>
      </div>
      <div>
        <button
          type="submit"
          id="btn-submit"
          class="w-full flex justify-center py-2.5 px-4 border border-transparent rounded-lg shadow-sm text-sm font-medium text-white bg-gray-900 hover:bg-gray-800 hover:shadow-gray-900/20 hover:-translate-y-0.5 transition-all focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-900 disabled:opacity-50 disabled:cursor-not-allowed cursor-pointer"
        >
          Sign Up
        </button>
      </div>
    </form>
    <div class="mt-8 text-center text-xs text-gray-400">
      <span>
        Copyright &copy; 2021-{new Date().getFullYear()} Waypoint.
      </span>
    </div>
  </div>
</AuthLayout>

<script>
  import { authClient } from "@/lib/auth-client";
  import Swal from "sweetalert2";

  const form = document.querySelector("form") as HTMLFormElement;
  const btnSubmit = document.querySelector("#btn-submit") as HTMLButtonElement;

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    btnSubmit.setAttribute("disabled", "disabled");

    const formData = new FormData(form);

    const email = formData.get("email") as string;
    const password = formData.get("password") as string;
    const rememberMe = formData.get("remember_me") === "on";

    if (rememberMe) {
      const expires = new Date(Date.now() + 1000 * 60 * 60 * 24 * 365);
      document.cookie = `email=${encodeURIComponent(email)}; path=/; expires=${expires.toUTCString()}`;
    } else {
      document.cookie = "email=; path=/; expires=Thu, 01 Jan 1970 00:00:00 GMT";
    }

    const { data, error } = await authClient.signUp.email({
      email,
      password,
      name: formData.get("name") as string,
      callbackURL: "/",
    });

    if (error) {
      Swal.fire({
        icon: "error",
        title: "Invalid credentials",
        text: error.message,
        confirmButtonColor: '#111827',
      });
      btnSubmit.removeAttribute("disabled");
      return;
    }
  });
</script>
