---
import MainLayout from "@/layouts/MainLayout.astro";
import { actions } from "astro:actions";
import { Formatter } from "@/utils";

const { data: products, error } = await Astro.callAction(
  actions.loadProductsFromCart,
  {},
);

if (error || !products) {
  return Astro.redirect("/");
}

const {session} = Astro.locals

const total = products.reduce(
  (acc, product) => acc + product.price * product.quantity,
  0,
);
---

<MainLayout>
  {
    products.length === 0 ? (
      <div class="empty-cart-container flex flex-col items-center justify-center min-h-[calc(100vh-160px)] py-10 text-center opacity-0">
        <div class="cart-icon bg-gray-100 p-6 rounded-full mb-6">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="64"
            height="64"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="text-gray-800"
          >
            <circle cx="9" cy="21" r="1"></circle>
            <circle cx="20" cy="21" r="1"></circle>
            <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
          </svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-light text-gray-900 mb-4 empty-title">Your cart is empty</h2>
        <p class="text-gray-500 max-w-md mx-auto mb-8 empty-text">
          Explore our exclusive collections, find your favorite items, and add them here to start shopping.
        </p>
        <a href="/products" class="bg-gray-900 text-white px-8 py-3 rounded hover:bg-gray-800 transition-colors empty-btn uppercase tracking-wide text-sm font-medium">
          Explore Products
        </a>
      </div>
    ) : (

        <h1 class="text-3xl">Cart</h1>
        
  <section class="grid grid-cols-1 sm:grid-cols-2">
    <div class="order-2 sm:order-1">
      {
        products.map(
          ({ image, title, slug, price, size, quantity, productId }) => (
            <div class="flex gap-5 mt-5 mx-5 text-gray-600 text-[15px]">
              <img src={image} alt={title} class="w-24 h-24 object-cover" />
              <div>
                <a
                  href={`/products/${slug}`}
                  class="hover:underline text-black"
                >
                  {title}
                </a>
                <p>${price}</p>
                <p>
                  Size: <span class="font-bold">{size}</span>{" "}
                </p>
                <span class="flex justify-between">
                  <p>
                    Quantity:
                    <select
                      name="quantity"
                      id="quantity"
                      data-id={productId}
                      data-size={size}
                      class="select-quantity"
                    >
                      <option value="1" selected={quantity === 1}>
                        1
                      </option>
                      <option value="2" selected={quantity === 2}>
                        2
                      </option>
                      <option value="3" selected={quantity === 3}>
                        3
                      </option>
                      <option value="4" selected={quantity === 4}>
                        4
                      </option>
                      <option value="5" selected={quantity === 5}>
                        5
                      </option>
                    </select>
                  </p>
                  <button
                    data-id={productId}
                    data-size={size}
                    class="btn-delete cursor-pointer underline underline-offset-4 hover:text-black transition-colors duration-300 "
                  >
                    Remove
                  </button>
                </span>
              </div>
            </div>
          ),
        )
      }
    </div>
    <div
      class="bg-white h-[330px] border-2 border-gray-300 text-black p-6 rounded-lg shadow-xl order-1"
    >
      <h2 class="text-lg! font-semibold mb-4">Order Summary</h2>

      <div class="flex justify-between text-gray-800 mb-2">
        <span>Shipping</span>
        <span>Free</span>
      </div>

      <div class="flex justify-between text-gray-800 mb-4">
        <span>SubTotal </span>
        <span>{Formatter.currency(total)}</span>
      </div>
      <div class="flex justify-between text-gray-800 mb-4">
        <span>Sales Tax </span>
        <span>{Formatter.currency(total * 0.15)}</span>
      </div>

      <div class="flex justify-between text-xl! font-bold">
        <span>Total</span>
        <span>{Formatter.currency(total * 1.15)}</span>
      </div>

      <button
      type="button"
      id="btn-buy"
      data-session={session ? "true" : "false"}
        class="mt-10 w-full bg-blue-700 text-white py-3 rounded-lg hover:bg-blue-800 transition-all cursor-pointer"
      >
        Buy
      </button>
    </div>
  </section>
)
}
</MainLayout>

<script>
  import { animate, stagger } from "animejs";
  import { itemsInCart } from "@/store/cart.store.";
  import { CartCookiesClient } from "@/utils";
  import { navigate } from "astro:transitions/client";
  import Swal from "sweetalert2";
  
  document.addEventListener("astro:page-load", () => {
    // Empty Cart Animations
    const emptyCart = document.querySelector(".empty-cart-container");
    if (emptyCart) {
      animate(emptyCart, {
        opacity: [0, 1],
        duration: 800,
        easing: "easeOutCubic"
      });
      animate('.cart-icon', {
        y: [-30, 0],
        opacity: [0, 1],
        duration: 1000,
        easing: "easeOutElastic(1, .6)"
      });
      animate(['.empty-title', '.empty-text', '.empty-btn'], {
        y: [20, 0],
        opacity: [0, 1],
        delay: stagger(100, { start: 200 }),
        duration: 800,
        easing: "easeOutCubic"
      });
    }

    const deleteButtons: NodeListOf<HTMLButtonElement> =
      document.querySelectorAll(".btn-delete");

    deleteButtons.forEach((button) => {
      button.addEventListener("click", (event) => {
        const target = event.target as HTMLButtonElement;
        const productId = target.dataset.id ?? " ";
        const size = target.dataset.size ?? " ";

        const cart = CartCookiesClient.removeItem(productId, size);
        itemsInCart.set(cart.length);

        // temporal
        navigate("/cart");
      });
    });

    const quantitySelects: NodeListOf<HTMLSelectElement> =
      document.querySelectorAll(".select-quantity");

    quantitySelects.forEach((select) => {
      select.addEventListener("change", (event) => {
        const target = event.target as HTMLSelectElement;
        const productId = target.dataset.id ?? "";
        const size = target.dataset.size ?? "";
        const quantity = parseInt(target.value);

        const cart = CartCookiesClient.updateQuantity(
          productId,
          size,
          quantity,
        );
        itemsInCart.set(cart.length);

        navigate("/cart");
      });
    });

    const btnBuy = document.querySelector("#btn-buy") as HTMLButtonElement; 

    if(btnBuy){
      btnBuy.addEventListener("click", () => {
        const isLoggedIn = btnBuy.dataset.session === "true";

        if(!isLoggedIn) {
           return Swal.fire({
                title: "Warning",
                text: "You need to be login to realize a buy, when you press ok you will be redirected to the login page",
                icon: "warning",
                confirmButtonText: "OK"
            }).then( () => {
                navigate("/login");
            })
        }
        Swal.fire({
            title: "Success",
            text: "Your order has been placed successfully. don't forget that this website is a demo",
            icon: "success",
            confirmButtonText: "OK"
        })
      })
    }
  });
</script>
