---
import "swiper/css";
import "swiper/css/pagination";

interface Props {
  images: string[];
}

const { images } = Astro.props;

const fullImages = images.map((img) => {
  return img.startsWith("http")
    ? img
    : `${import.meta.env.PUBLIC_URL}/images/products/${img}`;
});
---

<div class="col-span-1 sm:col-span-2 mb-10">
  <!-- Slider main container -->
  <div class="swiper main-swiper my-5">
    <div class="swiper-wrapper">
      {
        fullImages.map((image) => (
          <div class="swiper-slide cursor-zoom-in">
            <img
              src={image}
              alt="product image"
              class="w-full h-full object-cover px-10 transition-all duration-300"
            />
          </div>
        ))
      }
    </div>
    <!-- If we need pagination -->
    <div class="swiper-pagination"></div>
  </div>

  <!-- Thumbnails Slider -->
  <div class="swiper thumbs-swiper mt-2 h-24">
    <div class="swiper-wrapper">
      {
        fullImages.map((image) => (
          <div class="swiper-slide cursor-pointer opacity-60 transition-opacity rounded-md overflow-hidden bg-gray-100">
            <img
              src={image}
              alt="product thumbnail"
              class="w-full h-full object-cover"
            />
          </div>
        ))
      }
    </div>
  </div>
</div>

<style>
  .main-swiper {
    width: 100%;
    height: 600px;
    transition: all 0.3s ease;
  }

  .main-swiper.is-fullscreen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 50;
    background-color: white;
    margin: 0;
  }

  /* Cuando está en fullscreen mostramos la imagen completa sin el recorte */
  .main-swiper.is-fullscreen .swiper-slide img {
    object-fit: contain;
    padding: 2rem;
  }

  .thumbs-swiper .swiper-slide-thumb-active {
    opacity: 1 !important;
    border: 2px solid #000;
  }
</style>

<script>
  import Swiper from "swiper";
  import { Pagination, Thumbs, FreeMode } from "swiper/modules";

  document.addEventListener("astro:page-load", () => {
    // 1. Instanciar slider de miniaturas
    const thumbsSwiper = new Swiper(".thumbs-swiper", {
      spaceBetween: 10,
      slidesPerView: 4,
      freeMode: true,
      watchSlidesProgress: true,
      modules: [FreeMode],
    });

    // 2. Instanciar slider principal conectando los pulgares y la paginación
    const mainSwiper = new Swiper(".main-swiper", {
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
      thumbs: {
        swiper: thumbsSwiper,
      },
      modules: [Pagination, Thumbs],
    });

    // 3. Lógica para Fullscreen (Click) que no usa la API nativa del navegador
    const mainSwiperEl = document.querySelector(".main-swiper");
    const slideContainers = document.querySelectorAll(
      ".swiper-slide.cursor-zoom-in",
    );

    slideContainers.forEach((container) => {
      container.addEventListener("click", () => {
        mainSwiperEl?.classList.toggle("is-fullscreen");
        // Le decimos a swiper que recalcule sus dimensiones porque cambiaron los estilos
        mainSwiper.update();
      });
    });
  });
</script>
